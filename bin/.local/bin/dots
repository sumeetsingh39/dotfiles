#!/bin/bash
# dots.sh - Day to day dotfiles management
# Place at ~/.local/bin/dots
# Usage:
#   dots push "message"   — commit and push all changes
#   dots pull             — pull latest from GitHub
#   dots status           — show what's changed
#   dots add <package>    — add a new package to stow
#   dots list             — list all stowed packages

DOTFILES="$HOME/dotfiles"
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()    { echo -e "${BLUE}==>${NC} $1"; }
success() { echo -e "${GREEN} ✓${NC} $1"; }
warn()    { echo -e "${YELLOW} !${NC} $1"; }

cd "$DOTFILES" || { echo "dotfiles dir not found at $DOTFILES"; exit 1; }

case "$1" in
    push)
        msg="${2:-update dotfiles $(date '+%Y-%m-%d %H:%M')}"
        info "Pushing dotfiles: $msg"
        git add .
        git diff --cached --stat
        git commit -m "$msg" && git push && success "Pushed!" || warn "Nothing to push"
        ;;

    pull)
        info "Pulling latest dotfiles..."
        git pull && success "Up to date!" 
        ;;

    status)
        info "Dotfiles status:"
        git status -sb
        echo ""
        info "Stow symlinks:"
        for pkg in "$DOTFILES"/*/; do
            pkg_name=$(basename "$pkg")
            echo "  ✓ $pkg_name"
        done
        ;;

    add)
        pkg="$2"
        src="$3"
        [[ -z "$pkg" || -z "$src" ]] && {
            echo "Usage: dots add <package> <source-path>"
            echo "Example: dots add tmux .config/tmux"
            exit 1
        }
        full_src="$HOME/$src"
        [[ ! -e "$full_src" ]] && { warn "Source not found: $full_src"; exit 1; }

        pkg_dir="$DOTFILES/$pkg"
        target_dir="$pkg_dir/$(dirname "$src")"
        mkdir -p "$target_dir"

        cp -r "$full_src" "$target_dir/"
        rm -rf "$full_src"
        stow --dir="$DOTFILES" --target="$HOME" "$pkg"
        success "Added and stowed: $pkg"

        git add .
        git commit -m "add: $pkg config"
        git push
        success "Pushed!"
        ;;

    list)
        info "Stowed packages:"
        for pkg in "$DOTFILES"/*/; do
            pkg_name=$(basename "$pkg")
            [[ "$pkg_name" == "." || "$pkg_name" == ".." ]] && continue
            echo "  • $pkg_name"
        done
        ;;

    restow)
        info "Restowing all packages..."
        for pkg in "$DOTFILES"/*/; do
            pkg_name=$(basename "$pkg")
            stow --dir="$DOTFILES" --target="$HOME" --restow "$pkg_name" && \
                success "Restowed: $pkg_name"
        done
        ;;

    *)
        echo "Usage: dots <command>"
        echo ""
        echo "  push [message]       Commit and push all changes"
        echo "  pull                 Pull latest from GitHub"
        echo "  status               Show changed files and stowed packages"
        echo "  add <pkg> <path>     Add a new config to dotfiles"
        echo "  list                 List all stowed packages"
        echo "  restow               Restow all packages (after git pull)"
        echo ""
        echo "Examples:"
        echo "  dots push"
        echo "  dots push 'update sway gaps'"
        echo "  dots add tmux .config/tmux"
        ;;
esac
