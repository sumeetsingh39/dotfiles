{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "rosewater": "#f5e0dc",
    "flamingo": "#f2cdcd",
    "pink": "#f5c2e7",
    "mauve": "#cba6f7",
    "red": "#f38ba8",
    "maroon": "#eba0ac",
    "peach": "#fab387",
    "yellow": "#f9e2af",
    "green": "#a6e3a1",
    "teal": "#94e2d5",
    "sky": "#89dceb",
    "sapphire": "#74c7ec",
    "blue": "#89b4fa",
    "lavender": "#b4befe",
    "text": "#cdd6f4",
    "subtext1": "#bac2de",
    "subtext0": "#a6adc8",
    "overlay2": "#9399b2",
    "overlay1": "#7f849c",
    "overlay0": "#6c7086",
    "surface2": "#585b70",
    "surface1": "#45475a",
    "surface0": "#313244",
    "base": "#1e1e2e",
    "mantle": "#181825",
    "crust": "#11111b"
  },
  "transient_prompt": {
    "template": "ÔØ» ",
    "foreground": "p:text",
    "background": "transparent"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "root",
          "style": "plain",
          "foreground": "p:yellow",
          "template": "ÔÜí "
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "p:blue",
          "properties": {
            "cache_duration": "none",
            "style": "full"
          },
          "template": "{{ .Path }}"
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "p:mauve",
          "properties": {
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} <p:red>´üä {{ .Working.Count }}</>{{ end }}{{ if .Staging.Changed }} <p:green>´üå {{ .Staging.Count }}</>{{ end }}"
        },
        {
          "type": "node",
          "style": "plain",
          "foreground": "p:green",
          "template": " ¯£ÿ {{ .Full }}"
        },
        {
          "type": "python",
          "style": "plain",
          "foreground": "p:yellow",
          "template": " ¯êÁ {{ .Full }}"
        },
        {
          "type": "go",
          "style": "plain",
          "foreground": "p:teal",
          "template": " ¯ÿº {{ .Full }}"
        },
        {
          "type": "rust",
          "style": "plain",
          "foreground": "p:maroon",
          "template": " ¯×¿ {{ .Full }}"
        },
        {
          "type": "java",
          "style": "plain",
          "foreground": "p:peach",
          "template": " ¯£© {{ .Full }}"
        },
        {
          "type": "aws",
          "style": "plain",
          "foreground": "p:peach",
          "template": " ´ë░ {{.Profile}}{{if .Region}}@{{.Region}}{{end}}"
        },
        {
          "type": "kubectl",
          "style": "plain",
          "foreground": "p:sapphire",
          "template": " ´┤▒ {{.Context}}{{if .Namespace}} :: {{.Namespace}}{{end}}"
        }
      ],
      "newline": true
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "type": "sysinfo",
          "style": "plain",
          "foreground": "p:red",
          "template": "´íÜ {{ round .PhysicalPercentUsed .Precision }}% ",
          "properties": {
            "precision": 0,
            "threshold": 75
          }
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "p:yellow",
          "template": "{{ .FormattedMs }}",
          "properties": {
            "threshold": 500
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:green",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}"
          ],
          "template": "ÔØ»"
        }
      ],
      "newline": true
    }
  ],
  "version": 3,
  "final_space": true
}