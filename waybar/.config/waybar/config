{
  "layer": "top",
  "position": "top",
  "height": 32,
  "spacing": 6,
  "modules-left": [
    "sway/workspaces",
    "sway/mode",
    "sway/window"
  ],
  "sway/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "{name}",
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>",
    "tooltip": false
  },
  "modules-center": [
    "mpris"
  ],
  "sway/window": {
    "format": "{}",
    "max-length": 50
  },
  "modules-right": [
    "custom/audio",
    "backlight",
    "network",
    "custom/stats",
    "custom/weather",
    "battery",
    "clock",
    "custom/power"
  ],
  "custom/audio": {
    "exec": "~/.config/waybar/scripts/audio.sh",
    "interval": 1,
    "return-type": "json",
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume @DEFAULT_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_SINK@ 5%-"
  },
  "mpris": {
    "format": "   {player_icon} {status_icon} <i>{artist} - {title}</i>",
    "player": "playerctld",
    "max-length": 50,
    "on-click": "playerctl play-pause",
    "format-paused": "   {player_icon} {status_icon} {artist} - {title}",
    "player-icons": {
      "default": "🎵",
      "spotify": " ",
      "mpv": "🎵 "
    },
    "status-icons": {
      "paused": "⏸",
      "playing": "▶"
    }
  },
  "custom/keyboard-layout": {
    "exec": "i=$(swaymsg -t get_inputs); echo \"\"; echo \"$i\" | grep -m1 'xkb_active_layout_name' | cut -d '\"' -f4",
    "format": "",
    "interval": 30,
    "signal": 1,
    "on-click": "~/.config/waybar/scripts/keyhint.sh"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "",
      "deactivated": ""
    },
    "tooltip-format-activated": "Idle Inhibitor Activated",
    "tooltip-format-deactivated": "Idle Inhibitor Deactivated"
  },
  "cpu": {
    "interval": 5,
    "format": " {usage:>3}%",
    "states": {
      "warning": 70,
      "critical": 90
    },
    "on-click": "kitty --title waybar_htop -e htop"
  },
  "memory": {
    "interval": 5,
    "format": " {:>3}%",
    "on-click": "kitty --title waybar_htop -e htop",
    "states": {
      "warning": 70,
      "critical": 90
    }
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "󰄰",
      "󰪞",
      "󰪟",
      "󰪠",
      "󰪡",
      "󰪢",
      "󰪣",
      "󰪤",
      "󰪥"
    ],
    "tooltip-format": "Backlight (Scroll): {percent:}%",
    "on-scroll-down": "brightnessctl -c backlight set 2%-",
    "on-scroll-up": "brightnessctl -c backlight set +2%"
  },
  "pulseaudio": {
    "scroll-step": 2,
    "format": "{icon} {volume}%",
    "format-muted": "󰝟 muted",
    "format-icons": {
      "headphones": "",
      "handsfree": "",
      "headset": "",
      "phone": "",
      "portable": "",
      "car": "",
      "default": [
        "󰕿",
        "󰖀",
        "󰕾"
      ]
    },
    "on-click": "pavucontrol"
  },
  "custom/stats": {
    "exec": "~/.config/waybar/scripts/stats.sh",
    "interval": 5,
    "return-type": "json",
    "on-click": "kitty -e btop",
    "tooltip": true
  },
  "custom/weather": {
    "exec": "~/.config/waybar/scripts/weather.sh",
    "interval": 1800,
    "return-type": "json",
    "tooltip": true
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-icons": [
      "󰁺",
      "󰁻",
      "󰁼",
      "󰁽",
      "󰁾",
      "󰁿",
      "󰂀",
      "󰂁",
      "󰂂",
      "󰁹"
    ]
  },
  "network": {
    "format-wifi": " ",
    "format-ethernet": "{ipaddr}/{cidr}",
    "tooltip-format": "{essid}-({signalStrength}%)",
    "format-linked": "{ifname} (No IP)",
    "format-disconnected": "WiFi 󰌙",
    "on-click": "kitty -e nmtui"
  },
  "tray": {
    "icon-size": 16,
    "spacing": 10
  },
  "clock": {
    "interval": 60,
    "format": " {:%H:%M}",
    "format-alt": "󰃭 {:%a %d %b}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#8ec07c'><b>{}</b></span>",
        "days": "<span color='#ebdbb2'>{}</span>",
        "weeks": "<span color='#7c6f64'><i>W{}</i></span>",
        "today": "<span color='#fe8019'><b><u>{}</u></b></span>"
      }
    }
  },
  "custom/power": {
    "format": "⏻",
    "on-click": "exec ~/.config/sway/scripts/power_menu.sh",
    "tooltip": false
  }
}
